PORT=3000
PAYSHARK_API_URL=https://api.paysharkgateway.com.br/v1/transactions

# Configure conforme a autenticação fornecida pela PayShark.
# Exemplo Bearer:
AUTH_HEADER_NAME=Authorization
AUTH_HEADER_VALUE=Bearer COLE_SEU_TOKEN_AQUI

# WhatsApp para liberação manual. Somente números, com DDI e DDD.
# Exemplo: 5575999999999
WHATSAPP_NUMBER=

# URL pública do serviço no Render, usada como referência externa quando necessário.
PUBLIC_BASE_URL=
